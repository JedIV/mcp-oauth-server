# ============================================================
# Per-server OAuth Discovery & Endpoints
# ============================================================

@app.route('/servers/<server_name>/.well-known/openid-configuration')
def oidc_discovery(server_name):
    config = get_config()
    if server_name not in config.get('servers', {}):
        return make_response(json.dumps({'error': 'Unknown server'}), 404)

    preset = get_active_preset(config, server_name)
    mode = preset.get('oauth_mode', 'builtin')
    base_url = get_base_url()
    server_base = base_url + '/servers/' + server_name

    if mode == 'direct':
        auth_server = preset.get('authorization_server', '').rstrip('/')
        if auth_server:
            try:
                ext_resp = http_requests.get(auth_server + '/.well-known/openid-configuration', timeout=10)
                if ext_resp.status_code == 200:
                    resp = make_response(ext_resp.text)
                    resp.headers['Content-Type'] = 'application/json'
                    return resp
            except Exception as e:
                debug(f'OIDC DISCOVERY: Failed to proxy to {auth_server}: {e}')

    metadata = {
        'issuer': server_base,
        'authorization_endpoint': server_base + '/oauth/authorize',
        'token_endpoint': server_base + '/oauth/token',
        'introspection_endpoint': server_base + '/oauth/introspect',
        'registration_endpoint': server_base + '/oauth/register',
        'response_types_supported': ['code'],
        'grant_types_supported': ['authorization_code', 'refresh_token'],
        'code_challenge_methods_supported': ['S256', 'plain'],
        'scopes_supported': preset.get('scopes', ['mcp:tools', 'openid']),
        'token_endpoint_auth_methods_supported': ['client_secret_post', 'none'],
        'subject_types_supported': ['public'],
    }
    resp = make_response(json.dumps(metadata))
    resp.headers['Content-Type'] = 'application/json'
    return resp

@app.route('/servers/<server_name>/.well-known/oauth-authorization-server')
def oauth_as_metadata(server_name):
    return oidc_discovery(server_name)

@app.route('/servers/<server_name>/.well-known/oauth-protected-resource')
def oauth_protected_resource(server_name):
    """RFC 9728 Protected Resource Metadata."""
    config = get_config()
    if server_name not in config.get('servers', {}):
        return make_response(json.dumps({'error': 'Unknown server'}), 404)

    preset = get_active_preset(config, server_name)
    mode = preset.get('oauth_mode', 'builtin')
    base_url = get_base_url()
    server_base = base_url + '/servers/' + server_name

    if mode == 'direct':
        auth_server = preset.get('authorization_server', '').rstrip('/')
        metadata = {
            'resource': server_base + '/mcp',
            'authorization_servers': [auth_server] if auth_server else [server_base],
            'scopes_supported': preset.get('scopes', ['mcp:tools']),
            'bearer_methods_supported': ['header']
        }
    else:
        metadata = {
            'resource': server_base + '/mcp',
            'authorization_servers': [server_base],
            'scopes_supported': preset.get('scopes', ['mcp:tools']),
            'bearer_methods_supported': ['header']
        }

    resp = make_response(json.dumps(metadata))
    resp.headers['Content-Type'] = 'application/json'
    return resp

@app.route('/servers/<server_name>/oauth/register', methods=['POST'])
def oauth_register(server_name):
    config = get_config()
    if server_name not in config.get('servers', {}):
        return make_response(json.dumps({'error': 'Unknown server'}), 404)

    preset = get_active_preset(config, server_name)
    mode = preset.get('oauth_mode', 'builtin')

    if mode == 'external':
        body = request.get_json(force=True)
        client_data = {
            'client_id': preset.get('client_id', ''),
            'client_secret': preset.get('client_secret', ''),
            'client_name': body.get('client_name', 'MCP Client'),
            'redirect_uris': body.get('redirect_uris', []),
            'grant_types': body.get('grant_types', ['authorization_code']),
            'response_types': body.get('response_types', ['code']),
            'client_id_issued_at': int(time.time()),
        }
        resp = make_response(json.dumps(client_data))
        resp.headers['Content-Type'] = 'application/json'
        return resp, 201

    if mode == 'direct':
        return make_response(json.dumps({
            'error': 'invalid_request',
            'error_description': 'Direct mode: use the external authorization server for client registration'
        }), 400)

    # Built-in mode
    body = request.get_json(force=True)
    client_id = str(uuid.uuid4())
    client_secret = secrets.token_urlsafe(32)
    client_data = {
        'client_id': client_id,
        'client_secret': client_secret,
        'client_name': body.get('client_name', 'Unknown Client'),
        'redirect_uris': body.get('redirect_uris', []),
        'grant_types': body.get('grant_types', ['authorization_code']),
        'response_types': body.get('response_types', ['code']),
    }
    oauth_clients[client_id] = client_data
    resp = make_response(json.dumps({**client_data, 'client_id_issued_at': int(time.time())}))
    resp.headers['Content-Type'] = 'application/json'
    return resp, 201

@app.route('/servers/<server_name>/oauth/authorize', methods=['GET'])
def oauth_authorize(server_name):
    config = get_config()
    if server_name not in config.get('servers', {}):
        return make_response(json.dumps({'error': 'Unknown server'}), 404)

    preset = get_active_preset(config, server_name)
    mode = preset.get('oauth_mode', 'builtin')

    if mode == 'external':
        auth_server = preset.get('authorization_server', '').rstrip('/')
        try:
            oidc_resp = http_requests.get(auth_server + '/.well-known/openid-configuration', timeout=10)
            ext_authorize = oidc_resp.json().get('authorization_endpoint', '')
        except Exception as e:
            debug(f'AUTH PROXY: Failed to discover authorize endpoint: {e}')
            return make_response('Could not discover external authorization endpoint', 500)

        from urllib.parse import urlencode
        params = dict(request.args)
        params.pop('resource', None)
        debug(f'AUTH PROXY: Redirecting to {ext_authorize} with params: {params}')
        redirect_url = ext_authorize + '?' + urlencode(params)
        resp = make_response('', 302)
        resp.headers['Location'] = redirect_url
        return resp

    if mode == 'direct':
        return make_response('Direct mode: clients should authorize with the external server directly', 400)

    # Built-in mode
    client_id = request.args.get('client_id', '')
    redirect_uri = request.args.get('redirect_uri', '')
    scope = request.args.get('scope', 'mcp:tools')
    state = request.args.get('state', '')
    code_challenge = request.args.get('code_challenge', '')
    code_challenge_method = request.args.get('code_challenge_method', 'S256')

    if request.args.get('response_type', '') != 'code':
        return make_response('Unsupported response_type', 400)
    if client_id not in oauth_clients:
        return make_response('Unknown client: ' + client_id, 400)

    client_name = oauth_clients[client_id].get('client_name', client_id)
    burl = get_base_url()
    html = build_login_html(client_name, scope, client_id, redirect_uri, state, code_challenge, code_challenge_method, burl, server_name)
    resp = make_response(html)
    resp.headers['Content-Type'] = 'text/html'
    return resp

@app.route('/servers/<server_name>/oauth/authorize/submit', methods=['POST'])
def oauth_authorize_submit(server_name):
    username = request.form.get('username', '')
    password = request.form.get('password', '')
    client_id = request.form.get('client_id', '')
    redirect_uri = request.form.get('redirect_uri', '')
    scope = request.form.get('scope', 'mcp:tools')
    state = request.form.get('state', '')
    code_challenge = request.form.get('code_challenge', '')
    code_challenge_method = request.form.get('code_challenge_method', 'S256')

    if OAUTH_TEST_USERS.get(username) != password:
        return make_response('Invalid credentials', 401)

    code = secrets.token_urlsafe(32)
    oauth_auth_codes[code] = {
        'client_id': client_id,
        'redirect_uri': redirect_uri,
        'code_challenge': code_challenge,
        'code_challenge_method': code_challenge_method,
        'scope': scope,
        'user': username,
        'expires': time.time() + 300,
    }

    separator = '&' if '?' in redirect_uri else '?'
    redirect_url = redirect_uri + separator + 'code=' + code
    if state:
        redirect_url += '&state=' + state
    resp = make_response('', 302)
    resp.headers['Location'] = redirect_url
    return resp

@app.route('/servers/<server_name>/oauth/token', methods=['POST'])
def oauth_token(server_name):
    config = get_config()
    if server_name not in config.get('servers', {}):
        return make_response(json.dumps({'error': 'Unknown server'}), 404)

    preset = get_active_preset(config, server_name)
    mode = preset.get('oauth_mode', 'builtin')

    if mode == 'external':
        auth_server = preset.get('authorization_server', '').rstrip('/')
        try:
            oidc_resp = http_requests.get(auth_server + '/.well-known/openid-configuration', timeout=10)
            ext_token_url = oidc_resp.json().get('token_endpoint', '')
        except Exception as e:
            debug(f'TOKEN PROXY: Failed to discover token endpoint: {e}')
            return make_response(json.dumps({'error': 'server_error', 'error_description': 'Could not discover token endpoint'}), 500)

        form_data = request.form.to_dict() if request.form else {}
        form_data.pop('resource', None)
        debug(f'TOKEN PROXY: Forwarding to {ext_token_url}')

        ext_resp = http_requests.post(
            ext_token_url,
            data=form_data,
            headers={'Content-Type': 'application/x-www-form-urlencoded'},
            timeout=15
        )

        resp = make_response(ext_resp.text, ext_resp.status_code)
        resp.headers['Content-Type'] = ext_resp.headers.get('Content-Type', 'application/json')
        resp.headers['Cache-Control'] = 'no-store'
        return resp

    if mode == 'direct':
        return make_response(json.dumps({
            'error': 'invalid_request',
            'error_description': 'Direct mode: clients should exchange tokens with the external server directly'
        }), 400)

    # Built-in mode
    if request.content_type and 'json' in request.content_type:
        body = request.get_json(force=True)
    else:
        body = request.form.to_dict()

    grant_type = body.get('grant_type', '')
    if grant_type != 'authorization_code':
        return make_response(json.dumps({'error': 'unsupported_grant_type'}), 400)

    code = body.get('code', '')
    client_id = body.get('client_id', '')
    code_verifier = body.get('code_verifier', '')

    if code not in oauth_auth_codes:
        return make_response(json.dumps({'error': 'invalid_grant', 'error_description': 'Invalid or expired code'}), 400)

    code_data = oauth_auth_codes[code]
    if code_data['expires'] < time.time():
        del oauth_auth_codes[code]
        return make_response(json.dumps({'error': 'invalid_grant', 'error_description': 'Code expired'}), 400)
    if code_data['client_id'] != client_id:
        return make_response(json.dumps({'error': 'invalid_grant', 'error_description': 'Client mismatch'}), 400)

    if code_data.get('code_challenge'):
        if not code_verifier:
            return make_response(json.dumps({'error': 'invalid_grant', 'error_description': 'code_verifier required'}), 400)
        if not verify_pkce(code_verifier, code_data['code_challenge'], code_data.get('code_challenge_method', 'S256')):
            return make_response(json.dumps({'error': 'invalid_grant', 'error_description': 'PKCE verification failed'}), 400)

    del oauth_auth_codes[code]

    access_token = secrets.token_urlsafe(48)
    refresh_token = secrets.token_urlsafe(48)
    expires_in = 3600

    oauth_tokens_store[access_token] = {
        'client_id': client_id, 'scope': code_data['scope'],
        'user': code_data['user'], 'expires': time.time() + expires_in, 'active': True,
    }

    token_resp = {
        'access_token': access_token, 'token_type': 'Bearer',
        'expires_in': expires_in, 'refresh_token': refresh_token, 'scope': code_data['scope'],
    }
    resp = make_response(json.dumps(token_resp))
    resp.headers['Content-Type'] = 'application/json'
    resp.headers['Cache-Control'] = 'no-store'
    return resp

@app.route('/servers/<server_name>/oauth/introspect', methods=['POST'])
def oauth_introspect(server_name):
    token = request.form.get('token', '')
    if not token or token not in oauth_tokens_store:
        resp = make_response(json.dumps({'active': False}))
        resp.headers['Content-Type'] = 'application/json'
        return resp

    token_data = oauth_tokens_store[token]
    if token_data['expires'] < time.time():
        token_data['active'] = False

    result = {
        'active': token_data['active'], 'client_id': token_data['client_id'],
        'scope': token_data['scope'], 'sub': token_data['user'],
        'exp': int(token_data['expires']), 'aud': get_base_url(), 'token_type': 'Bearer',
    }
    resp = make_response(json.dumps(result))
    resp.headers['Content-Type'] = 'application/json'
    return resp


# ============================================================
# Routes: MCP Endpoint (per-server)
# ============================================================

@app.route('/servers/<server_name>/mcp', methods=['POST'])
@require_bearer_auth
def mcp_post(server_name):
    """MCP StreamableHTTP POST handler."""
    config = get_config()
    if server_name not in config.get('servers', {}):
        return make_response(json.dumps({'error': 'Unknown server'}), 404)

    body = request.get_json(force=True)
    session_id = request.headers.get('Mcp-Session-Id')

    if server_name not in sessions:
        sessions[server_name] = {}

    if not session_id:
        if isinstance(body, dict) and body.get('method') == 'initialize':
            new_session_id = str(uuid.uuid4())
            sessions[server_name][new_session_id] = {'created': time.time(), 'last_active': time.time()}

            result = handle_mcp_message(body, server_name)
            resp = make_response(json.dumps(result))
            resp.headers['Content-Type'] = 'application/json'
            resp.headers['Mcp-Session-Id'] = new_session_id
            return resp
        else:
            return make_response(json.dumps({
                'jsonrpc': '2.0',
                'error': {'code': -32000, 'message': 'Bad Request: No valid session ID'},
                'id': body.get('id') if isinstance(body, dict) else None
            }), 400)

    if session_id not in sessions.get(server_name, {}):
        return make_response(json.dumps({
            'jsonrpc': '2.0',
            'error': {'code': -32000, 'message': 'Invalid session ID'},
            'id': body.get('id') if isinstance(body, dict) else None
        }), 400)

    sessions[server_name][session_id]['last_active'] = time.time()

    if isinstance(body, list):
        results = [r for msg in body if (r := handle_mcp_message(msg, server_name)) is not None]
        resp = make_response(json.dumps(results))
    else:
        result = handle_mcp_message(body, server_name)
        if result is None:
            return make_response('', 202)
        resp = make_response(json.dumps(result))

    resp.headers['Content-Type'] = 'application/json'
    resp.headers['Mcp-Session-Id'] = session_id
    return resp

@app.route('/servers/<server_name>/mcp', methods=['GET'])
@require_bearer_auth
def mcp_get(server_name):
    """MCP StreamableHTTP GET handler (SSE stream, optional)."""
    session_id = request.headers.get('Mcp-Session-Id')
    if not session_id or session_id not in sessions.get(server_name, {}):
        return make_response('Invalid or missing session ID', 400)

    def generate():
        yield 'event: ping\ndata: {}\n\n'
    return Response(generate(), mimetype='text/event-stream')

@app.route('/servers/<server_name>/mcp', methods=['DELETE'])
@require_bearer_auth
def mcp_delete(server_name):
    """MCP session cleanup."""
    session_id = request.headers.get('Mcp-Session-Id')
    if session_id and server_name in sessions and session_id in sessions[server_name]:
        del sessions[server_name][session_id]
    return make_response('', 200)

# ============================================================
# Routes: Admin API (requires Dataiku auth)
# ============================================================

def require_dataiku_auth(f):
    """Require valid Dataiku session for admin endpoints."""
    @wraps(f)
    def decorated(*args, **kwargs):
        dku_api_key = request.headers.get('X-DKU-APIKey', '')
        if dku_api_key:
            try:
                import dataikuapi
                test_client = dataikuapi.DSSClient(
                    dataiku.api_client().host if hasattr(dataiku.api_client(), 'host') else get_config().get('base_url', '').split('/web-apps-backends')[0],
                    api_key=dku_api_key
                )
                test_client.list_project_keys()
                return f(*args, **kwargs)
            except Exception:
                return make_response(json.dumps({'error': 'Invalid API key'}), 401)

        if request.headers.get('X-DKU-AuthenticatedUser'):
            return f(*args, **kwargs)

        referer = request.headers.get('Referer', '')
        if '/projects/' in referer and '/webapps/' in referer:
            return f(*args, **kwargs)

        cookie = request.headers.get('Cookie', '')
        if 'dss_access_token_' in cookie or 'X-DKU-Flask-User' in cookie:
            return f(*args, **kwargs)

        return make_response(json.dumps({'error': 'Admin endpoints require Dataiku authentication'}), 401)
    return decorated

@app.route('/admin/config', methods=['GET'])
@require_dataiku_auth
def get_admin_config():
    """Return current config (sans secrets in presets)."""
    config = get_config()
    safe = dict(config)
    if 'presets' in safe:
        safe_presets = {}
        for key, preset in safe['presets'].items():
            sp = {k: v for k, v in preset.items() if k != 'client_secret'}
            sp['has_client_secret'] = bool(preset.get('client_secret'))
            safe_presets[key] = sp
        safe['presets'] = safe_presets
    safe.pop('client_secret', None)
    resp = make_response(json.dumps(safe))
    resp.headers['Content-Type'] = 'application/json'
    return resp

@app.route('/admin/config', methods=['POST'])
@require_dataiku_auth
def save_admin_config():
    """Save top-level config fields. OAuth fields go through preset endpoints."""
    new_config = request.get_json(force=True)
    existing = get_config()

    for key in ('presets', 'servers', 'base_url', 'config_version'):
        if key not in new_config and key in existing:
            new_config[key] = existing[key]

    new_config['config_version'] = 2
    save_config(new_config)
    resp = make_response(json.dumps({'status': 'ok'}))
    resp.headers['Content-Type'] = 'application/json'
    return resp

# ============================================================
# Routes: Server Management
# ============================================================

@app.route('/admin/servers', methods=['GET'])
@require_dataiku_auth
def list_servers():
    """List all servers."""
    config = get_config()
    servers = config.get('servers', {})
    base_url = get_base_url()
    result = {}
    for name, server in servers.items():
        preset_key = server.get('active_preset', '')
        preset = config.get('presets', {}).get(preset_key, {})
        agent = server.get('agent', {})
        result[name] = {
            'display_name': server.get('display_name', name),
            'active_preset': preset_key,
            'preset_name': preset.get('name', preset_key),
            'oauth_enabled': preset.get('oauth_enabled', False),
            'oauth_mode': preset.get('oauth_mode', ''),
            'agent': agent,
            'agent_configured': bool(agent.get('project_key') and agent.get('tool_ids')),
            'mcp_url': base_url + '/servers/' + name + '/mcp',
        }
    resp = make_response(json.dumps(result))
    resp.headers['Content-Type'] = 'application/json'
    return resp

@app.route('/admin/servers', methods=['POST'])
@require_dataiku_auth
def save_server():
    """Create or update a server. Body: {name, server_data}."""
    body = request.get_json(force=True)
    name = body.get('name', '').strip()
    server_data = body.get('server_data', {})

    if not name:
        return make_response(json.dumps({'error': 'Server name is required'}), 400)
    if not is_valid_server_name(name):
        return make_response(json.dumps({'error': 'Server name must be a URL-safe slug (lowercase letters, numbers, hyphens)'}), 400)

    config = get_config()
    if 'servers' not in config:
        config['servers'] = {}

    config['servers'][name] = server_data
    save_config(config)
    resp = make_response(json.dumps({'status': 'ok', 'name': name}))
    resp.headers['Content-Type'] = 'application/json'
    return resp

@app.route('/admin/servers/<name>', methods=['DELETE'])
@require_dataiku_auth
def delete_server(name):
    """Delete a server."""
    config = get_config()
    servers = config.get('servers', {})

    if name not in servers:
        return make_response(json.dumps({'error': 'Server not found'}), 404)

    del servers[name]
    # Clean up sessions
    sessions.pop(name, None)
    save_config(config)
    resp = make_response(json.dumps({'status': 'ok'}))
    resp.headers['Content-Type'] = 'application/json'
    return resp

# ============================================================
# Routes: Preset Management
# ============================================================

@app.route('/admin/presets', methods=['GET'])
@require_dataiku_auth
def list_presets():
    """List all presets (sans secrets)."""
    config = get_config()
    presets = config.get('presets', {})
    # Determine which presets are active on which servers
    active_on = {}
    for sname, sconf in config.get('servers', {}).items():
        pk = sconf.get('active_preset', '')
        if pk:
            active_on.setdefault(pk, []).append(sname)

    result = {}
    for key, preset in presets.items():
        safe = {k: v for k, v in preset.items() if k != 'client_secret'}
        safe['has_client_secret'] = bool(preset.get('client_secret'))
        safe['active_on_servers'] = active_on.get(key, [])
        result[key] = safe
    resp = make_response(json.dumps(result))
    resp.headers['Content-Type'] = 'application/json'
    return resp

@app.route('/admin/presets', methods=['POST'])
@require_dataiku_auth
def save_preset():
    """Create or update a preset. Body: {key, preset_data}."""
    body = request.get_json(force=True)
    key = body.get('key', '').strip()
    preset_data = body.get('preset_data', {})

    if not key:
        return make_response(json.dumps({'error': 'Preset key is required'}), 400)

    config = get_config()
    if 'presets' not in config:
        config['presets'] = {}

    if key in config['presets'] and 'client_secret' not in preset_data:
        existing_secret = config['presets'][key].get('client_secret')
        if existing_secret:
            preset_data['client_secret'] = existing_secret

    config['presets'][key] = preset_data
    save_config(config)
    resp = make_response(json.dumps({'status': 'ok', 'key': key}))
    resp.headers['Content-Type'] = 'application/json'
    return resp

@app.route('/admin/presets/<key>', methods=['DELETE'])
@require_dataiku_auth
def delete_preset(key):
    """Delete a preset. Cannot delete if active on any server."""
    config = get_config()
    presets = config.get('presets', {})

    if key not in presets:
        return make_response(json.dumps({'error': 'Preset not found'}), 404)

    # Check if active on any server
    for sname, sconf in config.get('servers', {}).items():
        if sconf.get('active_preset') == key:
            return make_response(json.dumps({
                'error': f'Cannot delete: preset is active on server "{sname}". Change the server\'s preset first.'
            }), 400)

    del presets[key]
    save_config(config)
    resp = make_response(json.dumps({'status': 'ok'}))
    resp.headers['Content-Type'] = 'application/json'
    return resp

# ============================================================
# Routes: Admin Utilities
# ============================================================

@app.route('/admin/project-keys', methods=['GET'])
@require_dataiku_auth
def list_project_keys():
    """List all project keys for autocomplete."""
    try:
        keys = dataiku.api_client().list_project_keys()
        resp = make_response(json.dumps(keys))
        resp.headers['Content-Type'] = 'application/json'
        return resp
    except Exception as e:
        logger.error(f"Error listing project keys: {e}")
        return make_response(json.dumps([]), 200)

@app.route('/admin/agents', methods=['GET'])
@require_dataiku_auth
def list_available_agents():
    """List agent tools, optionally filtered by project."""
    project_key = request.args.get('project_key', '')
    result = []

    try:
        c = dataiku.api_client()
        if project_key:
            project_keys = [project_key]
        else:
            project_keys = c.list_project_keys()

        for pk in project_keys:
            try:
                proj = c.get_project(pk)
                tools = proj.list_agent_tools()
                for t in tools:
                    result.append({
                        'project_key': pk,
                        'tool_id': t['id'],
                        'tool_name': t.get('name', t['id']),
                        'tool_type': t.get('type', 'unknown')
                    })
            except Exception:
                pass
    except Exception as e:
        logger.error(f"Error listing agents: {e}")

    resp = make_response(json.dumps(result))
    resp.headers['Content-Type'] = 'application/json'
    return resp

@app.route('/admin/discover', methods=['POST'])
@require_dataiku_auth
def discover_oauth():
    """Auto-discover OAuth endpoints from an issuer URL."""
    body = request.get_json(force=True)
    issuer_url = body.get('issuer_url', '').rstrip('/')

    if not issuer_url:
        return make_response(json.dumps({'error': 'issuer_url required'}), 400)

    for suffix in ['/.well-known/openid-configuration', '/.well-known/oauth-authorization-server']:
        try:
            resp = http_requests.get(issuer_url + suffix, timeout=10)
            if resp.status_code == 200:
                data = resp.json()
                result = {
                    'issuer': data.get('issuer', issuer_url),
                    'authorization_endpoint': data.get('authorization_endpoint', ''),
                    'token_endpoint': data.get('token_endpoint', ''),
                    'introspection_endpoint': data.get('introspection_endpoint', ''),
                    'registration_endpoint': data.get('registration_endpoint', ''),
                    'scopes_supported': data.get('scopes_supported', []),
                }
                r = make_response(json.dumps(result))
                r.headers['Content-Type'] = 'application/json'
                return r
        except Exception:
            continue

    return make_response(json.dumps({'error': 'Could not discover OAuth endpoints'}), 404)

@app.route('/admin/health')
@require_dataiku_auth
def health():
    """Health check endpoint with per-server status."""
    config = get_config()
    servers = config.get('servers', {})
    base_url = get_base_url()

    server_statuses = {}
    for name, server in servers.items():
        preset_key = server.get('active_preset', '')
        preset = config.get('presets', {}).get(preset_key, {})
        agent = server.get('agent', {})
        server_statuses[name] = {
            'display_name': server.get('display_name', name),
            'oauth_enabled': preset.get('oauth_enabled', False),
            'oauth_mode': preset.get('oauth_mode', ''),
            'preset_name': preset.get('name', ''),
            'agent_configured': bool(agent.get('project_key') and agent.get('tool_ids')),
            'mcp_url': base_url + '/servers/' + name + '/mcp',
        }

    any_configured = any(s['agent_configured'] for s in server_statuses.values()) if server_statuses else False
    any_oauth = any(s['oauth_enabled'] for s in server_statuses.values()) if server_statuses else False

    status = {
        'status': 'running',
        'server_count': len(servers),
        'servers': server_statuses,
        'any_agent_configured': any_configured,
        'any_oauth_enabled': any_oauth,
    }
    resp = make_response(json.dumps(status))
    resp.headers['Content-Type'] = 'application/json'
    return resp
