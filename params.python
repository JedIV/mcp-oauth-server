        state=state, code_challenge=code_challenge, code_challenge_method=code_challenge_method,
    )


# ============================================================
# Per-server OAuth Discovery & Endpoints
# ============================================================

@app.route('/servers/<server_name>/.well-known/openid-configuration')
def oidc_discovery(server_name):
    result = _get_server_or_404(server_name)
    if not result:
        return json_response({'error': 'Unknown server'}, 404)
    config, preset, mode = result
    base_url = get_base_url()
    server_base = base_url + '/servers/' + server_name

    if mode == 'direct':
        auth_server = preset.get('authorization_server', '').rstrip('/')
        if auth_server:
            metadata = _get_oidc_metadata(auth_server)
            if metadata:
                return json_response(metadata)

    return json_response({
        'issuer': server_base,
        'authorization_endpoint': server_base + '/oauth/authorize',
        'token_endpoint': server_base + '/oauth/token',
        'introspection_endpoint': server_base + '/oauth/introspect',
        'registration_endpoint': server_base + '/oauth/register',
        'response_types_supported': ['code'],
        'grant_types_supported': ['authorization_code', 'refresh_token'],
        'code_challenge_methods_supported': ['S256', 'plain'],
        'scopes_supported': preset.get('scopes', ['mcp:tools', 'openid']),
        'token_endpoint_auth_methods_supported': ['client_secret_post', 'none'],
        'subject_types_supported': ['public'],
    })

@app.route('/servers/<server_name>/.well-known/oauth-authorization-server')
def oauth_as_metadata(server_name):
    return oidc_discovery(server_name)

@app.route('/servers/<server_name>/.well-known/oauth-protected-resource')
def oauth_protected_resource(server_name):
    """RFC 9728 Protected Resource Metadata."""
    result = _get_server_or_404(server_name)
    if not result:
        return json_response({'error': 'Unknown server'}, 404)
    config, preset, mode = result
    base_url = get_base_url()
    server_base = base_url + '/servers/' + server_name

    auth_server = preset.get('authorization_server', '').rstrip('/') if mode == 'direct' else ''
    return json_response({
        'resource': server_base + '/mcp',
        'authorization_servers': [auth_server or server_base],
        'scopes_supported': preset.get('scopes', ['mcp:tools']),
        'bearer_methods_supported': ['header'],
    })

@app.route('/servers/<server_name>/oauth/register', methods=['POST'])
def oauth_register(server_name):
    result = _get_server_or_404(server_name)
    if not result:
        return json_response({'error': 'Unknown server'}, 404)
    config, preset, mode = result
    body = request.get_json(force=True)

    if mode == 'external':
        # Return client_id but NOT the real client_secret — the token proxy
        # injects credentials server-side, so clients don't need the secret.
        return json_response({
            'client_id': preset.get('client_id', ''),
            'client_secret': 'proxy-managed',
            'client_name': body.get('client_name', 'MCP Client'),
            'redirect_uris': body.get('redirect_uris', []),
            'grant_types': body.get('grant_types', ['authorization_code']),
            'response_types': body.get('response_types', ['code']),
            'client_id_issued_at': int(time.time()),
        }, 201)

    if mode == 'direct':
        return json_response({
            'error': 'invalid_request',
            'error_description': 'Direct mode: use the external authorization server for client registration'
        }, 400)

    # Built-in mode
    client_id = str(uuid.uuid4())
    client_secret = secrets.token_urlsafe(32)
    client_data = {
        'client_id': client_id,
        'client_secret': client_secret,
        'client_name': body.get('client_name', 'Unknown Client'),
        'redirect_uris': body.get('redirect_uris', []),
        'grant_types': body.get('grant_types', ['authorization_code']),
        'response_types': body.get('response_types', ['code']),
    }
    oauth_clients[server_name][client_id] = client_data
    return json_response({**client_data, 'client_id_issued_at': int(time.time())}, 201)

@app.route('/servers/<server_name>/oauth/authorize', methods=['GET'])
def oauth_authorize(server_name):
    result = _get_server_or_404(server_name)
    if not result:
        return json_response({'error': 'Unknown server'}, 404)
    config, preset, mode = result

    if mode == 'external':
        auth_server = preset.get('authorization_server', '').rstrip('/')
        metadata = _get_oidc_metadata(auth_server)
        if not metadata:
            return make_response('Could not discover external authorization endpoint', 500)

        ext_authorize = metadata.get('authorization_endpoint', '')
        params = dict(request.args)
        params.pop('resource', None)
        preset_client_id = preset.get('client_id', '')
        requested_client_id = params.get('client_id', '')
        if requested_client_id and preset_client_id and requested_client_id != preset_client_id:
            return make_response('client_id does not match configured OAuth client', 400)
        if preset_client_id:
            params['client_id'] = preset_client_id
        debug(f'AUTH PROXY: Redirecting to {ext_authorize}')
        resp = make_response('', 302)
        resp.headers['Location'] = ext_authorize + '?' + urlencode(params)
        return resp

    if mode == 'direct':
        return make_response('Direct mode: clients should authorize with the external server directly', 400)

    # Built-in mode
    _ensure_builtin_test_client(server_name)
    client_id = request.args.get('client_id', '')
    redirect_uri = request.args.get('redirect_uri', '')
    scope = request.args.get('scope', 'mcp:tools')
    state = request.args.get('state', '')
    code_challenge = request.args.get('code_challenge', '')
    code_challenge_method = request.args.get('code_challenge_method', 'S256')

    if request.args.get('response_type', '') != 'code':
        return make_response('Unsupported response_type', 400)
    if client_id not in oauth_clients[server_name]:
        return make_response('Unknown client: ' + client_id, 400)

    client_name = oauth_clients[server_name][client_id].get('client_name', client_id)
    burl = get_base_url()
    html = build_login_html(client_name, scope, client_id, redirect_uri, state, code_challenge, code_challenge_method, burl, server_name)
    resp = make_response(html)
    resp.headers['Content-Type'] = 'text/html'
    return resp

@app.route('/servers/<server_name>/oauth/authorize/submit', methods=['POST'])
def oauth_authorize_submit(server_name):
    _ensure_builtin_test_client(server_name)
    username = request.form.get('username', '')
    password = request.form.get('password', '')
    client_id = request.form.get('client_id', '')
    redirect_uri = request.form.get('redirect_uri', '')
    scope = request.form.get('scope', 'mcp:tools')
    state = request.form.get('state', '')
    code_challenge = request.form.get('code_challenge', '')
    code_challenge_method = request.form.get('code_challenge_method', 'S256')

    if OAUTH_TEST_USERS.get(username) != password:
        return make_response('Invalid credentials', 401)

    # Validate redirect_uri against client's registered URIs
    if client_id not in oauth_clients[server_name]:
        return make_response('Unknown client', 400)
    registered_uris = oauth_clients[server_name][client_id].get('redirect_uris', [])
    if redirect_uri not in registered_uris:
        return make_response('Invalid redirect_uri — not registered for this client', 400)

    code = secrets.token_urlsafe(32)
    oauth_auth_codes[server_name][code] = {
        'client_id': client_id,
        'redirect_uri': redirect_uri,
        'code_challenge': code_challenge,
        'code_challenge_method': code_challenge_method,
        'scope': scope,
        'user': username,
        'expires': time.time() + 300,
    }

    separator = '&' if '?' in redirect_uri else '?'
    redirect_url = redirect_uri + separator + 'code=' + code
    if state:
        redirect_url += '&state=' + state
    resp = make_response('', 302)
    resp.headers['Location'] = redirect_url
    return resp

def _get_request_body():
    """Parse request body as form-encoded or JSON (some clients send JSON for token requests)."""
    if request.form:
        return request.form.to_dict()
    return request.get_json(force=True) or {}

@app.route('/servers/<server_name>/oauth/token', methods=['POST'])
def oauth_token(server_name):
    result = _get_server_or_404(server_name)
    if not result:
        return json_response({'error': 'Unknown server'}, 404)
    config, preset, mode = result

    if mode == 'external':
        auth_server = preset.get('authorization_server', '').rstrip('/')
        metadata = _get_oidc_metadata(auth_server)
        if not metadata:
            return json_response({'error': 'server_error', 'error_description': 'Could not discover token endpoint'}, 500)

        ext_token_url = metadata.get('token_endpoint', '')
        form_data = _get_request_body()
        grant_type = form_data.get('grant_type', '')
        if grant_type not in ('authorization_code', 'refresh_token'):
            return json_response({
                'error': 'unsupported_grant_type',
                'error_description': f'Grant type "{grant_type}" is not permitted through the token proxy'
            }, 400)
        if grant_type == 'authorization_code':
            if not form_data.get('code'):
                return json_response({
                    'error': 'invalid_request',
                    'error_description': 'code is required'
                }, 400)
            if not form_data.get('code_verifier'):
                return json_response({
                    'error': 'invalid_request',
                    'error_description': 'code_verifier is required'
                }, 400)
        if grant_type == 'refresh_token' and not form_data.get('refresh_token'):
            return json_response({
                'error': 'invalid_request',
                'error_description': 'refresh_token is required'
            }, 400)
        form_data.pop('resource', None)
        # Always inject the real client credentials — clients may send the placeholder
        # "proxy-managed" secret from DCR, or omit credentials entirely (ChatGPT)
        form_data['client_id'] = preset.get('client_id', '')
        if preset.get('client_secret'):
            form_data['client_secret'] = preset['client_secret']
        debug(f'TOKEN PROXY: Forwarding to {ext_token_url} (keys={list(form_data.keys())})')

        ext_resp = http_requests.post(
            ext_token_url,
            data=form_data,
            headers={'Content-Type': 'application/x-www-form-urlencoded'},
            timeout=15
        )
        if ext_resp.status_code != 200:
            debug(f'TOKEN PROXY: {ext_resp.status_code}: {ext_resp.text[:500]}')

        resp = make_response(ext_resp.text, ext_resp.status_code)
        resp.headers['Content-Type'] = ext_resp.headers.get('Content-Type', 'application/json')
        resp.headers['Cache-Control'] = 'no-store'
        return resp

    if mode == 'direct':
        return json_response({
            'error': 'invalid_request',
            'error_description': 'Direct mode: clients should exchange tokens with the external server directly'
        }, 400)

    # Built-in mode
    body = _get_request_body()
    if body.get('grant_type') != 'authorization_code':
        return json_response({'error': 'unsupported_grant_type'}, 400)

    code = body.get('code', '')
    client_id = body.get('client_id', '')
    code_verifier = body.get('code_verifier', '')

    if code not in oauth_auth_codes[server_name]:
        return json_response({'error': 'invalid_grant', 'error_description': 'Invalid or expired code'}, 400)

    code_data = oauth_auth_codes[server_name][code]
    if code_data['expires'] < time.time():
        del oauth_auth_codes[server_name][code]
        return json_response({'error': 'invalid_grant', 'error_description': 'Code expired'}, 400)
    if code_data['client_id'] != client_id:
        return json_response({'error': 'invalid_grant', 'error_description': 'Client mismatch'}, 400)

    if code_data.get('code_challenge'):
        if not code_verifier:
            return json_response({'error': 'invalid_grant', 'error_description': 'code_verifier required'}, 400)
        if not verify_pkce(code_verifier, code_data['code_challenge'], code_data.get('code_challenge_method', 'S256')):
            return json_response({'error': 'invalid_grant', 'error_description': 'PKCE verification failed'}, 400)

    del oauth_auth_codes[server_name][code]

    access_token = secrets.token_urlsafe(48)
    refresh_token = secrets.token_urlsafe(48)
    expires_in = 3600

    oauth_tokens_store[server_name][access_token] = {
        'client_id': client_id, 'scope': code_data['scope'],
        'user': code_data['user'], 'expires': time.time() + expires_in, 'active': True,
    }

    resp = json_response({
        'access_token': access_token, 'token_type': 'Bearer',
        'expires_in': expires_in, 'refresh_token': refresh_token, 'scope': code_data['scope'],
    })
    resp.headers['Cache-Control'] = 'no-store'
    return resp

@app.route('/servers/<server_name>/oauth/introspect', methods=['POST'])
def oauth_introspect(server_name):
    token = request.form.get('token', '')
    if not token or token not in oauth_tokens_store[server_name]:
        return json_response({'active': False})

    td = oauth_tokens_store[server_name][token]
    if td['expires'] < time.time():
        td['active'] = False

    return json_response({
        'active': td['active'], 'client_id': td['client_id'],
        'scope': td['scope'], 'sub': td['user'],
        'exp': int(td['expires']), 'aud': get_base_url(), 'token_type': 'Bearer',
    })


# ============================================================
# Routes: MCP Endpoint (per-server)
# ============================================================

@app.route('/servers/<server_name>/mcp', methods=['POST'])
@require_bearer_auth
def mcp_post(server_name):
    """MCP StreamableHTTP POST handler."""
    if not _get_server_or_404(server_name):
        return json_response({'error': 'Unknown server'}, 404)

    body = request.get_json(force=True)
    session_id = request.headers.get('Mcp-Session-Id')
    msg_id = body.get('id') if isinstance(body, dict) else None

    if not session_id:
        if isinstance(body, dict) and body.get('method') == 'initialize':
            new_session_id = str(uuid.uuid4())
            sessions[server_name][new_session_id] = {'created': time.time(), 'last_active': time.time()}
            result = handle_mcp_message(body, server_name)
            resp = json_response(result)
            resp.headers['Mcp-Session-Id'] = new_session_id
            return resp
        return json_response({
            'jsonrpc': '2.0', 'id': msg_id,
            'error': {'code': -32000, 'message': 'Bad Request: No valid session ID'},
        }, 400)

    if session_id not in sessions.get(server_name, {}):
        return json_response({
            'jsonrpc': '2.0', 'id': msg_id,
            'error': {'code': -32000, 'message': 'Invalid session ID'},
        }, 400)

    sessions[server_name][session_id]['last_active'] = time.time()

    if isinstance(body, list):
        results = [r for msg in body if (r := handle_mcp_message(msg, server_name)) is not None]
        resp = json_response(results)
    else:
        result = handle_mcp_message(body, server_name)
        if result is None:
            return make_response('', 202)
        resp = json_response(result)

    resp.headers['Mcp-Session-Id'] = session_id
    return resp

@app.route('/servers/<server_name>/mcp', methods=['GET'])
@require_bearer_auth
def mcp_get(server_name):
    """MCP StreamableHTTP GET handler (SSE stream, optional)."""
    session_id = request.headers.get('Mcp-Session-Id')
    if not session_id or session_id not in sessions.get(server_name, {}):
        return make_response('Invalid or missing session ID', 400)

    def generate():
        yield 'event: ping\ndata: {}\n\n'
    return Response(generate(), mimetype='text/event-stream')

@app.route('/servers/<server_name>/mcp', methods=['DELETE'])
@require_bearer_auth
def mcp_delete(server_name):
    """MCP session cleanup."""
    session_id = request.headers.get('Mcp-Session-Id')
    if session_id and server_name in sessions and session_id in sessions[server_name]:
        del sessions[server_name][session_id]
    return make_response('', 200)

# ============================================================
# Routes: Admin API (requires Dataiku auth)
# ============================================================

def _check_project_access(auth_info):
    """Check whether the caller has access to this project.
    Project-scoped keys are inherently bound to the project.
    Personal API keys are checked against project permissions."""
    source = auth_info.get('authSource', '')

    # Project-scoped keys (webapp per-session keys) are inherently valid
    if source in ('CONFIGURABLE_API_KEY_PROJECT', 'PER_SESSION'):
        return True

    # For personal keys, check user/group against project permissions
    user = auth_info.get('authIdentifier', '')
    groups = set(auth_info.get('groups', []))

    # Administrators always have access
    if 'administrators' in groups:
        return True

    project_key = dataiku.api_client().get_default_project().project_key
    perms = dataiku.api_client().get_project(project_key).get_permissions()

    if perms.get('owner') == user:
        return True

    for perm in perms.get('permissions', []):
        if perm.get('user') == user:
            return True
        if perm.get('group') in groups:
            return True

    return False

def require_dataiku_auth(f):
    """Require valid Dataiku API key with project access for admin endpoints.
    Validates the key via get_auth_info(), then checks project access:
    - Project-scoped keys (webapp per-session): inherently project-bound
    - Personal API keys: verified against project permissions"""
    @wraps(f)
    def decorated(*args, **kwargs):
        dku_api_key = request.headers.get('X-DKU-APIKey', '')
        if not dku_api_key:
            return json_response({'error': 'Admin endpoints require Dataiku API key (X-DKU-APIKey header)'}, 401)

        try:
            dss_url = dataiku.api_client().host
            test_client = dataikuapi.DSSClient(dss_url, api_key=dku_api_key)
            auth_info = test_client.get_auth_info()
        except Exception:
            return json_response({'error': 'Invalid API key'}, 401)

        if not _check_project_access(auth_info):
            return json_response({'error': 'API key does not have access to this project'}, 403)

        return f(*args, **kwargs)
    return decorated

@app.route('/admin/config', methods=['GET'])
@require_dataiku_auth
def get_admin_config():
    """Return current config (sans secrets in presets)."""
    config = get_config()
    safe = dict(config)
    if 'presets' in safe:
        safe['presets'] = {k: _strip_secret(v) for k, v in safe['presets'].items()}
    return json_response(safe)

@app.route('/admin/config', methods=['POST'])
@require_dataiku_auth
def save_admin_config():
    """Save top-level config fields only (base_url). Presets and servers use their own CRUD endpoints."""
    new_config = request.get_json(force=True)
    existing = get_config()

    # Only allow updating base_url — presets/servers have dedicated endpoints
    PROTECTED_KEYS = {'presets', 'servers'}
    for key in PROTECTED_KEYS:
        if key in new_config:
            return json_response({'error': 'Cannot modify ' + key + ' through this endpoint; use dedicated CRUD endpoints'}, 400)

    # Preserve all existing keys, only update allowed fields
    merged = dict(existing)
    ALLOWED_KEYS = {'base_url'}
    for key in ALLOWED_KEYS:
        if key in new_config:
            merged[key] = new_config[key]

    save_config(merged)
    return json_response({'status': 'ok'})

# ============================================================
# Routes: Server Management
# ============================================================

def _build_server_status(name, server, config):
    """Build status dict for a server (shared by list_servers and health)."""
    preset_key = server.get('active_preset', '')
    preset = config.get('presets', {}).get(preset_key, {})
    agent = server.get('agent', {})
    return {
        'display_name': server.get('display_name', name),
        'active_preset': preset_key,
        'preset_name': preset.get('name', preset_key),
        'oauth_enabled': preset.get('oauth_enabled', False),
        'oauth_mode': preset.get('oauth_mode', ''),
        'agent': agent,
        'agent_configured': bool(agent.get('project_key') and agent.get('tool_ids')),
        'mcp_url': get_base_url() + '/servers/' + name + '/mcp',
    }

@app.route('/admin/servers', methods=['GET'])
@require_dataiku_auth
def list_servers():
    """List all servers."""
    config = get_config()
    result = {name: _build_server_status(name, srv, config)
              for name, srv in config.get('servers', {}).items()}
    return json_response(result)

@app.route('/admin/servers', methods=['POST'])
@require_dataiku_auth
def save_server():
    """Create or update a server. Body: {name, server_data}."""
    body = request.get_json(force=True)
    name = body.get('name', '').strip()
    server_data = body.get('server_data', {})

    if not name:
        return json_response({'error': 'Server name is required'}, 400)
    if not is_valid_server_name(name):
        return json_response({'error': 'Server name must be a URL-safe slug (lowercase letters, numbers, hyphens)'}, 400)

    config = get_config()
    config.setdefault('servers', {})[name] = server_data
    save_config(config)
    return json_response({'status': 'ok', 'name': name})

@app.route('/admin/servers/<name>', methods=['DELETE'])
@require_dataiku_auth
def delete_server(name):
    """Delete a server."""
    config = get_config()
    if name not in config.get('servers', {}):
        return json_response({'error': 'Server not found'}, 404)

    del config['servers'][name]
    sessions.pop(name, None)
    save_config(config)
    return json_response({'status': 'ok'})

# ============================================================
# Routes: Preset Management
# ============================================================

@app.route('/admin/presets', methods=['GET'])
@require_dataiku_auth
def list_presets():
    """List all presets (sans secrets)."""
    config = get_config()
    # Determine which presets are active on which servers
    active_on = {}
    for sname, sconf in config.get('servers', {}).items():
        pk = sconf.get('active_preset', '')
        if pk:
            active_on.setdefault(pk, []).append(sname)

    result = {}
    for key, preset in config.get('presets', {}).items():
        safe = _strip_secret(preset)
        safe['active_on_servers'] = active_on.get(key, [])
        result[key] = safe
    return json_response(result)

@app.route('/admin/presets', methods=['POST'])
@require_dataiku_auth
def save_preset():
    """Create or update a preset. Body: {key, preset_data}."""
    body = request.get_json(force=True)
    key = body.get('key', '').strip()
    preset_data = body.get('preset_data', {})

    if not key:
        return json_response({'error': 'Preset key is required'}, 400)

    # Validate URLs to prevent SSRF
    for url_field in ('authorization_server', 'introspection_endpoint'):
        url_err = _validate_url(preset_data.get(url_field, ''), url_field)
        if url_err:
            return json_response({'error': url_err}, 400)

    config = get_config()
    presets = config.setdefault('presets', {})

    # Preserve existing secret if not being updated
    if key in presets and 'client_secret' not in preset_data:
        existing_secret = presets[key].get('client_secret')
        if existing_secret:
            preset_data['client_secret'] = existing_secret

    presets[key] = preset_data
    save_config(config)
    return json_response({'status': 'ok', 'key': key})

@app.route('/admin/presets/<key>', methods=['DELETE'])
@require_dataiku_auth
def delete_preset(key):
    """Delete a preset. Cannot delete if active on any server."""
    config = get_config()
    presets = config.get('presets', {})

    if key not in presets:
        return json_response({'error': 'Preset not found'}, 404)

    for sname, sconf in config.get('servers', {}).items():
        if sconf.get('active_preset') == key:
            return json_response({
                'error': f'Cannot delete: preset is active on server "{sname}". Change the server\'s preset first.'
            }, 400)

    del presets[key]
    save_config(config)
    return json_response({'status': 'ok'})

# ============================================================
# Routes: Admin Utilities
# ============================================================

@app.route('/admin/project-keys', methods=['GET'])
@require_dataiku_auth
def list_project_keys():
    """List all project keys for autocomplete."""
    try:
        return json_response(dataiku.api_client().list_project_keys())
    except Exception as e:
        logger.error(f"Error listing project keys: {e}")
        return json_response([])

@app.route('/admin/agents', methods=['GET'])
@require_dataiku_auth
def list_available_agents():
    """List agent tools, optionally filtered by project."""
    project_key = request.args.get('project_key', '')
    result = []

    try:
        c = dataiku.api_client()
        if project_key:
            project_keys = [project_key]
        else:
            project_keys = c.list_project_keys()

        for pk in project_keys:
            try:
                proj = c.get_project(pk)
                tools = proj.list_agent_tools()
                for t in tools:
                    result.append({
                        'project_key': pk,
                        'tool_id': t['id'],
                        'tool_name': t.get('name', t['id']),
                        'tool_type': t.get('type', 'unknown')
                    })
            except Exception:
                pass
    except Exception as e:
        logger.error(f"Error listing agents: {e}")

    return json_response(result)

@app.route('/admin/discover', methods=['POST'])
@require_dataiku_auth
def discover_oauth():
    """Auto-discover OAuth endpoints from an issuer URL."""
    body = request.get_json(force=True)
    issuer_url = body.get('issuer_url', '').rstrip('/')

    if not issuer_url:
        return json_response({'error': 'issuer_url required'}, 400)

    url_err = _validate_url(issuer_url, 'Issuer URL')
    if url_err:
        return json_response({'error': url_err}, 400)

    data = _get_oidc_metadata(issuer_url)
    if not data:
        return json_response({'error': 'Could not discover OAuth endpoints'}, 404)

    return json_response({
        'issuer': data.get('issuer', issuer_url),
        'authorization_endpoint': data.get('authorization_endpoint', ''),
        'token_endpoint': data.get('token_endpoint', ''),
        'introspection_endpoint': data.get('introspection_endpoint', ''),
        'registration_endpoint': data.get('registration_endpoint', ''),
        'scopes_supported': data.get('scopes_supported', []),
    })

@app.route('/admin/health')
@require_dataiku_auth
def health():
    """Health check endpoint with per-server status."""
    config = get_config()
    statuses = {name: _build_server_status(name, srv, config)
                for name, srv in config.get('servers', {}).items()}

    return json_response({
        'status': 'running',
        'server_count': len(statuses),
        'servers': statuses,
        'any_agent_configured': any(s['agent_configured'] for s in statuses.values()) if statuses else False,
        'any_oauth_enabled': any(s['oauth_enabled'] for s in statuses.values()) if statuses else False,
    })

@app.route('/admin/debug-log')
@require_dataiku_auth
def get_debug_log():
    return json_response(list(_debug_log))
