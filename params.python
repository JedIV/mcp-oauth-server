@app.after_request
def add_cors_headers(response):
    response.headers['Access-Control-Allow-Origin'] = '*'
    response.headers['Access-Control-Allow-Methods'] = 'GET, POST, DELETE, OPTIONS'
    response.headers['Access-Control-Allow-Headers'] = 'Content-Type, Authorization, Mcp-Session-Id'
    response.headers['Access-Control-Expose-Headers'] = 'Mcp-Session-Id'
    return response

@app.route('/servers/<server_name>/mcp', methods=['OPTIONS'])
def mcp_options(server_name):
    return make_response('', 204)

# ============================================================
# Token Validation
# ============================================================

_oidc_metadata_cache = {}  # issuer_url -> (metadata_dict, expiry_time)
_jwks_client_cache = {}    # jwks_uri -> PyJWKClient

def _get_oidc_metadata(issuer_url):
    """Fetch and cache OIDC discovery metadata for an issuer."""
    now = time.time()
    cached = _oidc_metadata_cache.get(issuer_url)
    if cached and cached[1] > now:
        return cached[0]

    base = issuer_url.rstrip('/')
    for suffix in ['/.well-known/openid-configuration', '/.well-known/oauth-authorization-server']:
        try:
            resp = http_requests.get(base + suffix, timeout=10)
            if resp.status_code == 200:
                metadata = resp.json()
                _oidc_metadata_cache[issuer_url] = (metadata, now + 3600)
                return metadata
        except Exception:
            continue
    return None

def _discover_introspection_endpoint(preset):
    """Discover the introspection endpoint from OIDC metadata if not explicitly configured."""
    if preset.get('introspection_endpoint'):
        return preset['introspection_endpoint']
    auth_server = preset.get('authorization_server', '').rstrip('/')
    if not auth_server:
        return None
    metadata = _get_oidc_metadata(auth_server)
    return metadata.get('introspection_endpoint') if metadata else None

def _validate_token_introspection(token, preset):
    """Validate a token via the IdP's introspection endpoint (RFC 7662)."""
    introspection_url = _discover_introspection_endpoint(preset)
    client_id = preset.get('client_id', '')
    client_secret = preset.get('client_secret', '')

    if not introspection_url or not client_id:
        debug("TOKEN INTROSPECTION: No introspection endpoint or client_id configured")
        return None

    data = {'token': token, 'client_id': client_id}
    if client_secret:
        data['client_secret'] = client_secret

    try:
        debug(f"TOKEN INTROSPECTION: Calling {introspection_url}")
        resp = http_requests.post(
            introspection_url,
            data=data,
            headers={'Content-Type': 'application/x-www-form-urlencoded'},
            timeout=10
        )
        if resp.status_code != 200:
            debug(f"TOKEN INTROSPECTION: Returned {resp.status_code}: {resp.text[:200]}")
            return None

        result = resp.json()
        if not result.get('active', False):
            debug("TOKEN INTROSPECTION: Token is not active")
            return None
        debug(f"TOKEN INTROSPECTION: SUCCESS sub={result.get('sub')} scope={result.get('scp', result.get('scope'))}")
        return result
    except Exception as e:
        debug(f"TOKEN INTROSPECTION ERROR: {e}")
        return None

def _validate_token_jwt(token, preset):
    """Validate a JWT access token using JWKS (PyJWT + cryptography)."""
    auth_server = preset.get('authorization_server', '').rstrip('/')
    if not auth_server:
        debug("JWT VALIDATION: No authorization_server configured")
        return None

    metadata = _get_oidc_metadata(auth_server)
    if not metadata:
        debug(f"JWT VALIDATION: Could not fetch OIDC metadata from {auth_server}")
        return None

    jwks_uri = metadata.get('jwks_uri')
    issuer = metadata.get('issuer')
    if not jwks_uri:
        debug("JWT VALIDATION: No jwks_uri in OIDC metadata")
        return None

    try:
        if jwks_uri not in _jwks_client_cache:
            _jwks_client_cache[jwks_uri] = PyJWKClient(jwks_uri, cache_keys=True, lifespan=3600)
        signing_key = _jwks_client_cache[jwks_uri].get_signing_key_from_jwt(token)

        decode_kwargs = {
            'key': signing_key.key,
            'algorithms': ['RS256', 'RS384', 'RS512', 'ES256', 'ES384', 'ES512'],
            'options': {'verify_exp': True},
        }
        # Entra ID may issue v1 tokens (issuer: sts.windows.net/{tenant})
        # even when OIDC discovery reports the v2 issuer (login.microsoftonline.com/{tenant}/v2.0).
        # Accept both formats so issuer validation still works.
        if issuer:
            accepted_issuers = [issuer]
            # If v2 issuer, also accept the v1 equivalent
            m = re.match(r'https://login\.microsoftonline\.com/([^/]+)/v2\.0', issuer)
            if m:
                accepted_issuers.append(f'https://sts.windows.net/{m.group(1)}/')
            decode_kwargs['issuer'] = accepted_issuers
        client_id = preset.get('client_id', '')
        if client_id:
            # Entra v1 tokens use "api://{client_id}" as audience, v2 uses the client_id directly
            decode_kwargs['audience'] = [client_id, f'api://{client_id}']

        claims = pyjwt.decode(token, **decode_kwargs)

        debug(f"JWT VALIDATION: SUCCESS sub={claims.get('sub')} aud={claims.get('aud')} "
              f"scp={claims.get('scp', claims.get('scope'))}")
        return {
            'active': True,
            'sub': claims.get('sub', claims.get('oid', '')),
            'client_id': claims.get('azp', claims.get('appid', client_id)),
            'scope': claims.get('scp', claims.get('scope', '')),
            'claims': claims,
        }
    except pyjwt.ExpiredSignatureError:
        debug("JWT VALIDATION: Token expired")
        return None
    except pyjwt.InvalidAudienceError as e:
        debug(f"JWT VALIDATION: Invalid audience — {e}")
        return None
    except pyjwt.InvalidIssuerError as e:
        debug(f"JWT VALIDATION: Invalid issuer — {e}")
        return None
    except Exception as e:
        debug(f"JWT VALIDATION ERROR: {type(e).__name__}: {e}")
        return None

def validate_token(token, server_name):
    """Validate Bearer token for a specific server.
    Built-in mode: check in-memory store.
    External/Direct: try introspection first, then JWKS JWT verification."""
    config = get_config()
    preset = get_active_preset(config, server_name)
    mode = preset.get('oauth_mode', 'builtin')

    if mode == 'builtin':
        if token in oauth_tokens_store[server_name]:
            td = oauth_tokens_store[server_name][token]
            if td['expires'] < time.time():
                td['active'] = False
            if td['active']:
                return {'active': True, 'client_id': td['client_id'], 'scope': td['scope'], 'sub': td['user']}
        return None

    # External and Direct modes: try introspection first (preferred, RFC 7662)
    result = _validate_token_introspection(token, preset)
    if result:
        return result

    # Fallback: JWKS-based JWT signature verification (for Entra ID, etc.)
    debug("TOKEN VALIDATION: Introspection unavailable, trying JWKS JWT verification")
    return _validate_token_jwt(token, preset)

def get_base_url():
    """Get the externally-reachable base URL for this webapp."""
    config = get_config()
    if config.get('base_url'):
        return config['base_url'].rstrip('/')
    return request.url_root.rstrip('/')

def require_bearer_auth(f):
    """Decorator: require OAuth Bearer token on MCP endpoints. Uses server_name from URL."""
    @wraps(f)
    def decorated(*args, **kwargs):
        server_name = kwargs.get('server_name', 'default')
        config = get_config()
        preset = get_active_preset(config, server_name)

        if not preset.get('oauth_enabled', False):
            debug(f'MCP AUTH: OAuth disabled for server={server_name}, passing through')
            return f(*args, **kwargs)

        auth_header = request.headers.get('Authorization', '')
        debug(f'MCP AUTH: server={server_name} method={request.method} has_bearer={auth_header.startswith("Bearer ")}')
        if not auth_header.startswith('Bearer '):
            base_url = get_base_url()
            resp = make_response('', 401)
            resp.headers['WWW-Authenticate'] = (
                'Bearer realm="mcp", '
                'resource_metadata="' + base_url + '/servers/' + server_name + '/.well-known/oauth-protected-resource"'
            )
            return resp

        token = auth_header[7:]
        token_data = validate_token(token, server_name)
        if token_data is None:
            debug(f'MCP AUTH: Token validation failed for server={server_name} token={token[:20]}...')
            resp = make_response('', 401)
            resp.headers['WWW-Authenticate'] = 'Bearer error="invalid_token"'
            return resp

        request.token_data = token_data
        return f(*args, **kwargs)
    return decorated

# ============================================================
# MCP Protocol (StreamableHTTP, JSON-RPC 2.0)
# ============================================================

sessions = defaultdict(dict)  # server_name -> {session_id -> {created, last_active}}

def handle_mcp_message(message, server_name):
    """Route a single MCP JSON-RPC message to the right handler."""
    method = message.get('method', '')
    msg_id = message.get('id')
    params = message.get('params', {})

    handlers = {
        'initialize': handle_initialize,
        'notifications/initialized': lambda p, i, s: None,
        'tools/list': handle_tools_list,
        'tools/call': handle_tools_call,
        'ping': lambda p, i, s: {'jsonrpc': '2.0', 'id': i, 'result': {}},
    }

    handler = handlers.get(method)
    if handler:
        return handler(params, msg_id, server_name)

    return {
        'jsonrpc': '2.0',
        'id': msg_id,
        'error': {'code': -32601, 'message': f'Method not found: {method}'}
    }

def handle_initialize(params, msg_id, server_name):
    config = get_config()
    server = get_server_config(config, server_name)
    display_name = server.get('display_name', server_name)
    return {
        'jsonrpc': '2.0',
        'id': msg_id,
        'result': {
            'protocolVersion': '2025-03-26',
            'capabilities': {
                'tools': {'listChanged': False}
            },
            'serverInfo': {
                'name': f'dataiku-mcp-{server_name}',
                'version': '1.0.0'
            }
        }
    }

def handle_tools_list(params, msg_id, server_name):
    config = get_config()
    tools = build_tool_definitions(config, server_name)
    return {
        'jsonrpc': '2.0',
        'id': msg_id,
        'result': {'tools': tools}
    }

def handle_tools_call(params, msg_id, server_name):
    tool_name = params.get('name', '')
    arguments = params.get('arguments', {})
    result = call_agent_tool(tool_name, arguments, server_name)
    return {
        'jsonrpc': '2.0',
        'id': msg_id,
        'result': result
    }

# ============================================================
# Agent Tool Integration
# ============================================================

def build_tool_definitions(config, server_name):
    """Build MCP tool definitions from configured Dataiku agent tools for a server."""
    tools = []
    server = get_server_config(config, server_name)
    agent_config = server.get('agent', {})
    project_key = agent_config.get('project_key', '')
    tool_ids = agent_config.get('tool_ids', [])

    if not project_key or not tool_ids:
        return tools

    api_client = dataiku.api_client()
    project = api_client.get_project(project_key)

    for tool_id in tool_ids:
        try:
            tool = project.get_agent_tool(tool_id)
            tool_raw = tool.get_settings().get_raw()
            tool_name = tool_raw.get('name', tool_id)
            description = tool_raw.get('description', '')
            if not description:
                description = f'Dataiku agent tool: {tool_name} (type: {tool_raw.get("type", "unknown")})'
            tools.append({
                'name': tool_name,
                'description': description,
                'inputSchema': {
                    'type': 'object',
                    'properties': {
                        'query': {
                            'type': 'string',
                            'description': 'The query to send to the agent tool'
                        }
                    },
                    'required': ['query']
                }
            })
        except Exception as e:
            logger.error(f"Error loading tool {tool_id}: {e}")

    return tools

def call_agent_tool(tool_name, arguments, server_name):
    """Execute a Dataiku agent tool and return MCP-formatted result."""
    config = get_config()
    server = get_server_config(config, server_name)
    agent_config = server.get('agent', {})
    project_key = agent_config.get('project_key', '')

    try:
        api_client = dataiku.api_client()
        project = api_client.get_project(project_key)

        tool_id = tool_name
        for tid in agent_config.get('tool_ids', []):
            t = project.get_agent_tool(tid)
            t_raw = t.get_settings().get_raw()
            if t_raw.get('name', tid) == tool_name:
                tool_id = tid
                break

        tool = project.get_agent_tool(tool_id)
        query = arguments.get('query', '')
        output = tool.run({'question': query})

        response_text = output.get('output', {}).get('response', json.dumps(output))
        return {
            'content': [{'type': 'text', 'text': response_text}]
        }
    except Exception as e:
        logger.error(f"Error calling tool {tool_name}: {e}")
        return {
            'content': [{'type': 'text', 'text': f'Error: {str(e)}'}],
            'isError': True
        }


