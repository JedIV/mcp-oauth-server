logger = logging.getLogger(__name__)


def json_response(data, status=200):
    """Return a JSON response with correct Content-Type."""
    resp = make_response(json.dumps(data), status)
    resp.headers['Content-Type'] = 'application/json'
    return resp

# ============================================================
# Configuration Management (stored in project variables)
# ============================================================

PRESET_FIELDS = {'oauth_mode', 'oauth_enabled', 'authorization_server', 'client_id',
                 'client_secret', 'scopes', 'introspection_endpoint'}

SERVER_NAME_RE = re.compile(r'^[a-z0-9][a-z0-9_-]{0,38}[a-z0-9]$|^[a-z0-9]$')

def _validate_url(url, field_name='URL'):
    """Validate that a URL is safe (HTTPS only, no private/local targets).
    Resolves hostnames to IPs to block DNS rebinding and internal-pointing hostnames."""
    if not url:
        return None  # Empty is fine (field not set)
    parsed = urlparse(url)
    if parsed.scheme not in ('https',):
        return f'{field_name} must use HTTPS (got {parsed.scheme}://)'
    host = parsed.hostname or ''
    if not host:
        return f'{field_name} has no hostname'
    # Block localhost literals
    if host in ('localhost', '127.0.0.1', '0.0.0.0', '::1', '[::1]'):
        return f'{field_name} cannot target localhost'
    # Resolve hostname and check all resulting IPs
    try:
        addrinfos = socket.getaddrinfo(host, None, socket.AF_UNSPEC, socket.SOCK_STREAM)
    except socket.gaierror:
        return f'{field_name} hostname could not be resolved'
    for family, _, _, _, sockaddr in addrinfos:
        ip = ipaddress.ip_address(sockaddr[0])
        if ip.is_private or ip.is_loopback or ip.is_link_local or ip.is_reserved:
            return f'{field_name} resolves to a private/reserved IP address'
    return None

def is_valid_server_name(name):
    return bool(SERVER_NAME_RE.match(name))

def get_config():
    """Load MCP OAuth config from project variables."""
    try:
        project = dataiku.api_client().get_default_project()
        variables = project.get_variables()
        return variables.get('standard', {}).get('mcp_oauth_config', {}) or {'presets': {}, 'servers': {}}
    except Exception as e:
        logger.error(f"Error loading config: {e}")
        return {'presets': {}, 'servers': {}}

def save_config(config):
    """Save MCP OAuth config to project variables."""
    project = dataiku.api_client().get_default_project()
    variables = project.get_variables()
    if 'standard' not in variables:
        variables['standard'] = {}
    variables['standard']['mcp_oauth_config'] = config
    project.set_variables(variables)

def get_server_config(config, server_name):
    """Get a server's config dict from the top-level config."""
    return config.get('servers', {}).get(server_name, {})

def _strip_secret(preset):
    """Return a preset dict with client_secret replaced by a has_client_secret flag."""
    safe = {k: v for k, v in preset.items() if k != 'client_secret'}
    safe['has_client_secret'] = bool(preset.get('client_secret'))
    return safe

def get_active_preset(config, server_name=None):
    """Get the active preset dict for a server."""
    presets = config.get('presets', {})
    if server_name:
        server = get_server_config(config, server_name)
        active_key = server.get('active_preset', '')
        if active_key and active_key in presets:
            return presets[active_key]
    return {}

def _get_server_or_404(server_name):
    """Load config and verify server exists. Returns (config, preset, mode) or raises a 404 response."""
    config = get_config()
    if server_name not in config.get('servers', {}):
        return None
    preset = get_active_preset(config, server_name)
    mode = preset.get('oauth_mode', 'builtin')
    return config, preset, mode

# ============================================================
# Debug log (in-memory ring buffer for troubleshooting)
# ============================================================
_debug_log = deque([{'t': 0, 'msg': '--- restart ---'}], maxlen=200)

def debug(msg):
    _debug_log.append({'t': time.time(), 'msg': str(msg)})
    logger.info(msg)

# debug-log route registered after require_dataiku_auth is defined (see bottom of admin section)

