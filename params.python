import dataiku
import json
import uuid
import time
import logging
import re
import requests as http_requests
from functools import wraps
from flask import request, make_response, Response

logger = logging.getLogger(__name__)

# ============================================================
# Configuration Management (stored in project variables)
# ============================================================

PRESET_FIELDS = {'oauth_mode', 'oauth_enabled', 'authorization_server', 'client_id',
                 'client_secret', 'scopes', 'introspection_endpoint'}

SERVER_NAME_RE = re.compile(r'^[a-z0-9][a-z0-9_-]{0,38}[a-z0-9]$|^[a-z0-9]$')

def is_valid_server_name(name):
    return bool(SERVER_NAME_RE.match(name))

def get_config():
    """Load MCP OAuth config from project variables, auto-migrating to v2 format."""
    try:
        project = dataiku.api_client().get_default_project()
        variables = project.get_variables()
        config = variables.get('standard', {}).get('mcp_oauth_config', {})

        # Auto-migrate v1 (flat/presets) to v2 (servers)
        if config.get('config_version') != 2:
            config = _migrate_to_v2(config)
            if 'standard' not in variables:
                variables['standard'] = {}
            variables['standard']['mcp_oauth_config'] = config
            project.set_variables(variables)
            logger.info("Auto-migrated config to v2 (multi-server)")

        return config
    except Exception as e:
        logger.error(f"Error loading config: {e}")
        return {'config_version': 2, 'presets': {}, 'servers': {}}

def _migrate_to_v2(config):
    """Migrate any older config format to v2 with servers dict."""
    # First ensure presets exist (handle pre-preset flat config)
    if 'presets' not in config and config.get('oauth_mode'):
        config = _migrate_flat_to_presets(config)

    presets = config.get('presets', {})
    active_preset = config.get('active_preset', '')
    agent = config.get('agent', {})

    new_config = {
        'config_version': 2,
        'presets': presets,
        'servers': {},
    }

    # Preserve base_url if set
    if config.get('base_url'):
        new_config['base_url'] = config['base_url']

    # If there was an agent or active preset, create a 'default' server
    if agent or active_preset:
        new_config['servers']['default'] = {
            'display_name': 'Default',
            'active_preset': active_preset,
            'agent': agent,
        }

    return new_config

def _migrate_flat_to_presets(config):
    """Migrate a flat config (pre-presets) into the preset structure."""
    mode = config.get('oauth_mode', 'builtin')
    preset_key = mode + '-default'

    preset_data = {'name': _default_preset_name(mode)}
    for field in PRESET_FIELDS:
        if field in config:
            preset_data[field] = config[field]

    new_config = {}
    for k, v in config.items():
        if k not in PRESET_FIELDS:
            new_config[k] = v
    new_config['presets'] = {preset_key: preset_data}
    new_config['active_preset'] = preset_key

    return new_config

def _default_preset_name(mode):
    names = {
        'builtin': 'Built-in (Testing)',
        'external': 'External IdP',
        'direct': 'Direct OAuth 2.1',
    }
    return names.get(mode, mode)

def save_config(config):
    """Save MCP OAuth config to project variables."""
    project = dataiku.api_client().get_default_project()
    variables = project.get_variables()
    if 'standard' not in variables:
        variables['standard'] = {}
    variables['standard']['mcp_oauth_config'] = config
    project.set_variables(variables)

def get_server_config(config, server_name):
    """Get a server's config dict from the top-level config."""
    return config.get('servers', {}).get(server_name, {})

def get_active_preset(config, server_name=None):
    """Get the active preset dict for a server. Falls back gracefully."""
    presets = config.get('presets', {})
    if server_name:
        server = get_server_config(config, server_name)
        active_key = server.get('active_preset', '')
    else:
        active_key = ''
    if active_key and active_key in presets:
        return presets[active_key]
    if presets:
        return next(iter(presets.values()))
    return {}

def get_oauth_mode(config, server_name=None):
    """Get the current OAuth mode from the active preset for a server."""
    preset = get_active_preset(config, server_name)
    return preset.get('oauth_mode', 'builtin')

# ============================================================
# Debug log (in-memory ring buffer for troubleshooting)
# ============================================================
_debug_log = [{'t': 0, 'msg': '--- restart ---'}]

def debug(msg):
    _debug_log.append({'t': time.time(), 'msg': str(msg)})
    if len(_debug_log) > 200:
        _debug_log.pop(0)
    logger.info(msg)

@app.route('/admin/debug-log')
def get_debug_log():
    resp = make_response(json.dumps(_debug_log, indent=2))
    resp.headers['Content-Type'] = 'application/json'
    return resp

# ============================================================
# CORS handling
# ============================================================

@app.after_request
def add_cors_headers(response):
    response.headers['Access-Control-Allow-Origin'] = '*'
    response.headers['Access-Control-Allow-Methods'] = 'GET, POST, DELETE, OPTIONS'
    response.headers['Access-Control-Allow-Headers'] = 'Content-Type, Authorization, Mcp-Session-Id'
    response.headers['Access-Control-Expose-Headers'] = 'Mcp-Session-Id'
    return response

@app.route('/servers/<server_name>/mcp', methods=['OPTIONS'])
def mcp_options(server_name):
    return make_response('', 204)

# ============================================================
# Token Validation
# ============================================================

_jwks_cache = {'keys': None, 'fetched_at': 0}

def get_jwks(jwks_uri):
    """Fetch and cache JWKS keys from the OAuth provider."""
    now = time.time()
    if _jwks_cache['keys'] and (now - _jwks_cache['fetched_at']) < 3600:
        return _jwks_cache['keys']
    try:
        resp = http_requests.get(jwks_uri, timeout=10)
        if resp.status_code == 200:
            _jwks_cache['keys'] = resp.json()
            _jwks_cache['fetched_at'] = now
            return _jwks_cache['keys']
    except Exception as e:
        logger.error(f"JWKS fetch error: {e}")
    return _jwks_cache.get('keys')

def validate_token_jwt(token, preset):
    """Validate a JWT token by decoding and checking claims."""
    client_id = preset.get('client_id', '')

    try:
        parts = token.split('.')
        if len(parts) != 3:
            debug("JWT VALIDATION: Not a valid JWT (wrong number of parts)")
            return None

        payload_b64 = parts[1]
        payload_b64 += '=' * (4 - len(payload_b64) % 4)
        payload_json = base64.urlsafe_b64decode(payload_b64)
        claims = json.loads(payload_json)

        debug(f'JWT CLAIMS: iss={claims.get("iss")} aud={claims.get("aud")} sub={claims.get("sub")} scp={claims.get("scp")} exp={claims.get("exp")}')

        exp = claims.get('exp', 0)
        if exp < time.time():
            debug("JWT VALIDATION: Token expired")
            return None

        aud = claims.get('aud', '')
        valid_audiences = [client_id, f'api://{client_id}']
        if aud not in valid_audiences:
            debug(f'JWT VALIDATION: Audience mismatch: got {aud}, expected one of {valid_audiences}')
            return None

        iss = claims.get('iss', '')
        if iss and 'windows.net' not in iss and 'microsoftonline.com' not in iss:
            auth_server = preset.get('authorization_server', '').rstrip('/')
            if auth_server and not iss.startswith(auth_server):
                debug(f'JWT VALIDATION: Issuer mismatch: got {iss}')
                return None

        debug(f'JWT VALIDATION: SUCCESS sub={claims.get("sub")} name={claims.get("name")}')
        return {
            'active': True,
            'client_id': claims.get('azp', claims.get('appid', '')),
            'scope': claims.get('scp', ''),
            'sub': claims.get('sub', claims.get('oid', '')),
            'name': claims.get('name', ''),
        }
    except Exception as e:
        debug(f'JWT VALIDATION ERROR: {type(e).__name__}: {e}')
        return None

def validate_token(token, server_name):
    """Validate Bearer token for a specific server. Supports built-in OAuth, JWT, and introspection."""
    config = get_config()
    preset = get_active_preset(config, server_name)
    mode = preset.get('oauth_mode', 'builtin')

    if mode == 'builtin':
        if token in oauth_tokens_store:
            td = oauth_tokens_store[token]
            if td['expires'] < time.time():
                td['active'] = False
            if td['active']:
                return {'active': True, 'client_id': td['client_id'], 'scope': td['scope'], 'sub': td['user']}
        return None

    if mode == 'external':
        if token.count('.') == 2:
            result = validate_token_jwt(token, preset)
            if result is not None:
                return result

    introspection_url = preset.get('introspection_endpoint', '')
    client_id = preset.get('client_id', '')
    client_secret = preset.get('client_secret', '')

    if not introspection_url or not client_id:
        if mode == 'external':
            logger.warning("External mode: JWT validation failed and no introspection endpoint configured")
        else:
            logger.warning("Direct mode: no introspection endpoint configured")
        return None

    data = {'token': token, 'client_id': client_id}
    if client_secret:
        data['client_secret'] = client_secret

    try:
        resp = http_requests.post(
            introspection_url,
            data=data,
            headers={'Content-Type': 'application/x-www-form-urlencoded'},
            timeout=10
        )
        if resp.status_code != 200:
            logger.error(f"Introspection returned {resp.status_code}")
            return None

        result = resp.json()
        if not result.get('active', False):
            return None
        return result
    except Exception as e:
        logger.error(f"Token validation error: {e}")
        return None

def get_base_url():
    """Get the externally-reachable base URL for this webapp."""
    config = get_config()
    if config.get('base_url'):
        return config['base_url'].rstrip('/')
    return request.url_root.rstrip('/')

def require_bearer_auth(f):
    """Decorator: require OAuth Bearer token on MCP endpoints. Uses server_name from URL."""
    @wraps(f)
    def decorated(*args, **kwargs):
        server_name = kwargs.get('server_name', 'default')
        config = get_config()
        preset = get_active_preset(config, server_name)

        if not preset.get('oauth_enabled', False):
            return f(*args, **kwargs)

        auth_header = request.headers.get('Authorization', '')
        if not auth_header.startswith('Bearer '):
            base_url = get_base_url()
            resp = make_response('', 401)
            resp.headers['WWW-Authenticate'] = (
                'Bearer realm="mcp", '
                'resource_metadata="' + base_url + '/servers/' + server_name + '/.well-known/oauth-protected-resource"'
            )
            return resp

        token = auth_header[7:]
        token_data = validate_token(token, server_name)
        if token_data is None:
            debug(f'MCP AUTH: Token validation failed for server={server_name} token={token[:20]}...')
            resp = make_response('', 401)
            resp.headers['WWW-Authenticate'] = 'Bearer error="invalid_token"'
            return resp

        request.token_data = token_data
        return f(*args, **kwargs)
    return decorated

# ============================================================
# MCP Protocol (StreamableHTTP, JSON-RPC 2.0)
# ============================================================

sessions = {}  # sessions[server_name][session_id] -> {created, last_active}

def handle_mcp_message(message, server_name):
    """Route a single MCP JSON-RPC message to the right handler."""
    method = message.get('method', '')
    msg_id = message.get('id')
    params = message.get('params', {})

    handlers = {
        'initialize': handle_initialize,
        'notifications/initialized': lambda p, i, s: None,
        'tools/list': handle_tools_list,
        'tools/call': handle_tools_call,
        'ping': lambda p, i, s: {'jsonrpc': '2.0', 'id': i, 'result': {}},
    }

    handler = handlers.get(method)
    if handler:
        return handler(params, msg_id, server_name)

    return {
        'jsonrpc': '2.0',
        'id': msg_id,
        'error': {'code': -32601, 'message': f'Method not found: {method}'}
    }

def handle_initialize(params, msg_id, server_name):
    config = get_config()
    server = get_server_config(config, server_name)
    display_name = server.get('display_name', server_name)
    return {
        'jsonrpc': '2.0',
        'id': msg_id,
        'result': {
            'protocolVersion': '2025-03-26',
            'capabilities': {
                'tools': {'listChanged': False}
            },
            'serverInfo': {
                'name': f'dataiku-mcp-{server_name}',
                'version': '1.0.0'
            }
        }
    }

def handle_tools_list(params, msg_id, server_name):
    config = get_config()
    tools = build_tool_definitions(config, server_name)
    return {
        'jsonrpc': '2.0',
        'id': msg_id,
        'result': {'tools': tools}
    }

def handle_tools_call(params, msg_id, server_name):
    tool_name = params.get('name', '')
    arguments = params.get('arguments', {})
    result = call_agent_tool(tool_name, arguments, server_name)
    return {
        'jsonrpc': '2.0',
        'id': msg_id,
        'result': result
    }

# ============================================================
# Agent Tool Integration
# ============================================================

def build_tool_definitions(config, server_name):
    """Build MCP tool definitions from configured Dataiku agent tools for a server."""
    tools = []
    server = get_server_config(config, server_name)
    agent_config = server.get('agent', {})
    project_key = agent_config.get('project_key', '')
    tool_ids = agent_config.get('tool_ids', [])

    if not project_key or not tool_ids:
        return tools

    api_client = dataiku.api_client()
    project = api_client.get_project(project_key)

    for tool_id in tool_ids:
        try:
            tool = project.get_agent_tool(tool_id)
            tool_raw = tool.get_settings().get_raw()
            tool_name = tool_raw.get('name', tool_id)
            description = tool_raw.get('description', '')
            if not description:
                description = f'Dataiku agent tool: {tool_name} (type: {tool_raw.get("type", "unknown")})'
            tools.append({
                'name': tool_name,
                'description': description,
                'inputSchema': {
                    'type': 'object',
                    'properties': {
                        'query': {
                            'type': 'string',
                            'description': 'The query to send to the agent tool'
                        }
                    },
                    'required': ['query']
                }
            })
        except Exception as e:
            logger.error(f"Error loading tool {tool_id}: {e}")

    return tools

def call_agent_tool(tool_name, arguments, server_name):
    """Execute a Dataiku agent tool and return MCP-formatted result."""
    config = get_config()
    server = get_server_config(config, server_name)
    agent_config = server.get('agent', {})
    project_key = agent_config.get('project_key', '')

    try:
        api_client = dataiku.api_client()
        project = api_client.get_project(project_key)

        tool_id = tool_name
        for tid in agent_config.get('tool_ids', []):
            t = project.get_agent_tool(tid)
            t_raw = t.get_settings().get_raw()
            if t_raw.get('name', tid) == tool_name:
                tool_id = tid
                break

        tool = project.get_agent_tool(tool_id)
        query = arguments.get('query', '')
        output = tool.run({'question': query})

        response_text = output.get('output', {}).get('response', json.dumps(output))
        return {
            'content': [{'type': 'text', 'text': response_text}]
        }
    except Exception as e:
        logger.error(f"Error calling tool {tool_name}: {e}")
        return {
            'content': [{'type': 'text', 'text': f'Error: {str(e)}'}],
            'isError': True
        }


